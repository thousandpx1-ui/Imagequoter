# ── Clerk Authentication ──────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → Your App → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# ── Cloudflare AI Gateway ─────────────────────────────────────────────────────
# How to get your gateway URL:
#   1. Go to https://dash.cloudflare.com
#   2. Click "AI" → "AI Gateway" → Create a gateway
#   3. In your gateway, click "OpenAI" provider
#   4. Copy the URL — it looks like:
#      https://gateway.ai.cloudflare.com/v1/{account_id}/{gateway_name}/openai
#
VITE_CF_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/YOUR_ACCOUNT_ID/YOUR_GATEWAY_NAME/openai

# ── Cloudflare Gateway Auth Token (optional) ─────────────────────────────────
# Only needed if your gateway has "Require cf-aig-authorization header" enabled.
# Leave blank (or delete this line) if your gateway auth is set to "None".
VITE_CF_API_TOKEN=
